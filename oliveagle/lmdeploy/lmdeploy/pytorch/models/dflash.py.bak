"""DFlash (Draft Flash) speculative decoding model for lmdeploy PyTorch backend.

DFlash is a diffusion-based speculative decoding method that generates all draft tokens
in parallel. It uses target model intermediate hidden states as context and mask token
embeddings as diffusion noise.

Key differences from EAGLE:
- Parallel generation (not autoregressive)
- Custom attention: Q from draft, KV from concat(target_hidden + draft_hidden)
- Non-causal attention pattern
"""

from typing import Any, Dict, Iterable, List, Optional, Tuple

import torch
from torch import nn
from transformers import PretrainedConfig

from lmdeploy.pytorch.model_inputs import StepContext, StepContextManager
from lmdeploy.pytorch.nn import ApplyRotaryEmb, RMSNorm, build_rotary_embedding_from_config
from lmdeploy.pytorch.nn.linear import (build_down_linear, build_gateup_linear, build_o_proj,
                                        build_qkv_proj, build_rowwise_linear)
from lmdeploy.pytorch.weight_loader.model_weight_loader import load_weight

from .patch import add_prefix
from .utils.cudagraph import CudaGraphMixin


class DFlashAttention(nn.Module):
    """DFlash attention layer.

    Q from draft hidden states
    KV from concatenation of target_hidden (context) + draft_hidden (noise)
    Non-causal attention (all tokens attend to each other)
    """

    def __init__(self,
                 config: PretrainedConfig,
                 dtype: torch.dtype = None,
                 device: torch.device = None,
                 prefix: str = ''):
        super().__init__()
        self.config = config
        quantization_config = getattr(config, 'quantization_config', None)

        num_heads = config.num_attention_heads
        num_key_value_heads = getattr(config, 'num_key_value_heads', num_heads)
        hidden_size = config.hidden_size
        head_dim = getattr(config, 'head_dim', hidden_size // num_heads)

        self.num_heads = num_heads
        self.num_key_value_heads = num_key_value_heads
        self.head_dim = head_dim

        if num_key_value_heads == num_heads:
            self.num_key_value_groups = 1
        else:
            self.num_key_value_groups = num_heads // num_key_value_heads

        # Q projection from draft hidden states (standard linear, not QKV)
        self.q_proj = build_rowwise_linear(
            hidden_size,
            num_heads * head_dim,
            bias=getattr(config, 'attention_bias', False),
            quant_config=quantization_config,
            dtype=dtype,
            device=device,
            is_tp=False,
            prefix=add_prefix('q_proj', prefix),
        )

        # K/V projections - single projection used for both context and noise
        # The checkpoint has one k_proj and one v_proj, we use them for both
        self.k_proj = build_rowwise_linear(
            hidden_size,
            num_key_value_heads * head_dim,
            bias=getattr(config, 'attention_bias', False),
            quant_config=quantization_config,
            dtype=dtype,
            device=device,
            is_tp=False,
            prefix=add_prefix('k_proj', prefix),
        )
        self.v_proj = build_rowwise_linear(
            hidden_size,
            num_key_value_heads * head_dim,
            bias=getattr(config, 'attention_bias', False),
            quant_config=quantization_config,
            dtype=dtype,
            device=device,
            is_tp=False,
            prefix=add_prefix('v_proj', prefix),
        )

        # O projection
        self.o_proj = build_o_proj(
            num_heads * head_dim,
            hidden_size,
            bias=getattr(config, 'attention_bias', False),
            quant_config=quantization_config,
            dtype=dtype,
            device=device,
            is_tp=True,
            prefix=add_prefix('o_proj', prefix),
        )

        # Q/K norms
        self.q_norm = RMSNorm(head_dim, config.rms_norm_eps, dtype=dtype, device=device)
        self.k_norm = RMSNorm(head_dim, config.rms_norm_eps, dtype=dtype, device=device)

        # Rotary embedding
        self.apply_rotary_pos_emb = ApplyRotaryEmb()

        # Scaling factor
        self.scaling = head_dim ** -0.5

    def forward(
        self,
        hidden_states: torch.Tensor,
        target_hidden: torch.Tensor,
        rotary_pos_emb: Tuple[torch.Tensor, torch.Tensor],
    ) -> torch.Tensor:
        """DFlash attention forward.

        Uses non-causal flash attention via Triton kernel for efficiency.
        Each draft token attends to all target context tokens + all draft tokens.
        """
        # Handle both 2D and 3D inputs
        if hidden_states.dim() == 3:
            batch_size, seq_len, hidden_dim = hidden_states.shape
            num_tokens = batch_size * seq_len
            hidden_states = hidden_states.reshape(num_tokens, hidden_dim)
        else:
            num_tokens, hidden_dim = hidden_states.shape
            batch_size = num_tokens
            seq_len = 1

        # target_hidden is already projected: [batch*seq, hidden_size]
        if target_hidden.dim() == 3:
            target_batch, target_seq, target_dim = target_hidden.shape
            target_hidden = target_hidden.reshape(target_batch * target_seq, target_dim)

        # Q from draft hidden states
        q_states = self.q_proj(hidden_states)
        q_states = q_states.view(num_tokens, self.num_heads, self.head_dim)
        q_states = self.q_norm(q_states)

        # K/V from target (context) - already projected by FC layer
        k_ctx = self.k_proj(target_hidden[:num_tokens])
        v_ctx = self.v_proj(target_hidden[:num_tokens])
        k_noise = self.k_proj(hidden_states)
        v_noise = self.v_proj(hidden_states)

        # Reshape
        k_ctx = k_ctx.view(num_tokens, self.num_key_value_heads, self.head_dim)
        v_ctx = v_ctx.view(num_tokens, self.num_key_value_heads, self.head_dim)
        k_noise = k_noise.view(num_tokens, self.num_key_value_heads, self.head_dim)
        v_noise = v_noise.view(num_tokens, self.num_key_value_heads, self.head_dim)

        # Normalize K
        k_ctx = self.k_norm(k_ctx)
        k_noise = self.k_norm(k_noise)

        # Add context and noise (element-wise, like residual)
        k_states = k_ctx + k_noise
        v_states = v_ctx + v_noise

        # Apply RoPE to Q and K
        cos, sin = rotary_pos_emb
        q_states, k_states = self.apply_rotary_pos_emb(
            q_states,
            k_states,
            cos,
            sin,
            inplace=True,
        )

        # GQA: repeat k/v if needed
        if self.num_key_value_groups > 1:
            k_states = k_states.repeat_interleave(self.num_key_value_groups, dim=1)
            v_states = v_states.repeat_interleave(self.num_key_value_groups, dim=1)

        # Use flash_attn_varlen_func for efficient non-causal attention
        # DFlash: all N tokens attend to all N tokens simultaneously
        from lmdeploy.pytorch.kernels.cuda import flash_attn_varlen_func

        device = q_states.device
        cu_seqlens_q = torch.tensor([0, num_tokens], dtype=torch.int32, device=device)
        cu_seqlens_k = torch.tensor([0, num_tokens], dtype=torch.int32, device=device)
        max_seqlen_q = num_tokens
        max_seqlen_k = num_tokens

        attn_output = flash_attn_varlen_func(
            q_states,
            k_states,
            v_states,
            cu_seqlens_q=cu_seqlens_q,
            cu_seqlens_k=cu_seqlens_k,
            max_seqlen_q=max_seqlen_q,
            max_seqlen_k=max_seqlen_k,
            softmax_scale=self.scaling,
            causal=False,
            kv_layout='hsd',
        )

        attn_output = attn_output.view(num_tokens, -1)
        return self.o_proj(attn_output)


class DFlashDecoderLayer(nn.Module):
    """DFlash decoder layer."""

    def __init__(self,
                 config: PretrainedConfig,
                 layer_idx: int,
                 dtype: torch.dtype = None,
                 device: torch.device = None,
                 prefix: str = ''):
        super().__init__()
        self.layer_idx = layer_idx
        quantization_config = getattr(config, 'quantization_config', None)

        # Self attention
        self.self_attn = DFlashAttention(
            config,
            dtype=dtype,
            device=device,
            prefix=add_prefix('self_attn', prefix),
        )

        # MLP
        self.gate_up_proj = build_gateup_linear(
            config.hidden_size,
            [config.intermediate_size, config.intermediate_size],
            bias=False,
            dtype=dtype,
            device=device,
            quant_config=quantization_config,
            is_tp=True,
            prefix=add_prefix('gate_up_proj', prefix),
        )
        self.down_proj = build_down_linear(
            config.intermediate_size,
            config.hidden_size,
            bias=False,
            quant_config=quantization_config,
            dtype=dtype,
            device=device,
            is_tp=True,
            prefix=add_prefix('down_proj', prefix),
        )

        # Layer norms
        self.input_layernorm = RMSNorm(
            config.hidden_size,
            config.rms_norm_eps,
            quant_config=quantization_config,
            dtype=dtype,
            device=device,
            prefix=add_prefix('input_layernorm', prefix),
        )
        self.post_attention_layernorm = RMSNorm(
            config.hidden_size,
            config.rms_norm_eps,
            quant_config=quantization_config,
            dtype=dtype,
            device=device,
            prefix=add_prefix('post_attention_layernorm', prefix),
        )

    def forward(
        self,
        target_hidden: torch.Tensor,
        hidden_states: torch.Tensor,
        rotary_pos_emb: Tuple[torch.Tensor, torch.Tensor],
    ) -> torch.Tensor:
        """Forward pass.

        Args:
            target_hidden: Target hidden context
            hidden_states: Draft hidden states (noise)
            rotary_pos_emb: (cos, sin) for RoPE

        Returns:
            Output hidden states
        """
        residual = hidden_states
        hidden_states = self.input_layernorm(hidden_states)
        hidden_states = self.self_attn(hidden_states, target_hidden, rotary_pos_emb)
        hidden_states = residual + hidden_states

        residual = hidden_states
        hidden_states = self.post_attention_layernorm(hidden_states)
        gate_up = self.gate_up_proj(hidden_states)
        # SiLU gate * up
        gate, up = gate_up.chunk(2, dim=-1)
        hidden_states = torch.nn.functional.silu(gate) * up
        hidden_states = self.down_proj(hidden_states)
        hidden_states = residual + hidden_states

        return hidden_states


class DFlashModel(nn.Module):
    """DFlash model body."""

    def __init__(self,
                 config: PretrainedConfig,
                 dtype: torch.dtype = None,
                 device: torch.device = None,
                 prefix: str = ''):
        super().__init__()
        self.config = config
        self.padding_idx = config.pad_token_id
        self.vocab_size = config.vocab_size

        # Embeddings (shared with target model during loading)
        self.embed_tokens = nn.Embedding(
            config.vocab_size,
            config.hidden_size,
            self.padding_idx,
            dtype=dtype,
            device=device,
        )

        # Decoder layers
        self.layers = nn.ModuleList([
            DFlashDecoderLayer(
                config,
                layer_idx,
                dtype=dtype,
                device=device,
                prefix=add_prefix(f'layers.{layer_idx}', prefix),
            )
            for layer_idx in range(config.num_hidden_layers)
        ])

        # Final norm
        self.norm = RMSNorm(
            config.hidden_size,
            config.rms_norm_eps,
            dtype=dtype,
            device=device,
        )

        # FC layer to project concatenated target hidden states
        # Get target_layer_ids from dflash_config
        dflash_cfg = getattr(config, 'dflash_config', None)
        if dflash_cfg is not None:
            if isinstance(dflash_cfg, dict):
                target_layer_ids = dflash_cfg.get('target_layer_ids', [1, 10, 19, 28, 37])
            else:
                target_layer_ids = getattr(dflash_cfg, 'target_layer_ids', [1, 10, 19, 28, 37])
        else:
            target_layer_ids = [1, 10, 19, 28, 37]

        num_target_layers = len(target_layer_ids)
        self.fc = nn.Linear(
            num_target_layers * config.hidden_size,
            config.hidden_size,
            bias=False,
            dtype=dtype,
            device=device,
        )
        self.hidden_norm = RMSNorm(
            config.hidden_size,
            config.rms_norm_eps,
            dtype=dtype,
            device=device,
        )

        # Rotary embedding
        self.rotary_emb = build_rotary_embedding_from_config(config, device=device)

    def forward(
        self,
        input_ids: Optional[torch.Tensor] = None,
        target_hidden: Optional[torch.Tensor] = None,
        position_ids: Optional[torch.Tensor] = None,
        inputs_embeds: Optional[torch.Tensor] = None,
    ) -> torch.Tensor:
        """Forward pass.

        Args:
            input_ids: Draft token IDs (for embedding lookup)
            target_hidden: Concatenated target hidden states [batch*seq, num_layers*hidden]
            position_ids: Position IDs for draft tokens
            inputs_embeds: Pre-computed embeddings (optional)

        Returns:
            Output hidden states
        """
        # Get embeddings
        if inputs_embeds is None:
            inputs_embeds = self.embed_tokens(input_ids)

        # Project target_hidden
        target_hidden_proj = self.fc(target_hidden)
        target_hidden_proj = self.hidden_norm(target_hidden_proj)

        # Rotary embedding
        cos, sin = self.rotary_emb(inputs_embeds, position_ids)
        rotary_pos_emb = (cos, sin)

        # Decode through layers
        hidden_states = inputs_embeds
        for layer in self.layers:
            hidden_states = layer(target_hidden_proj, hidden_states, rotary_pos_emb)

        # Final norm
        hidden_states = self.norm(hidden_states)

        return hidden_states

    def get_input_embeddings(self):
        """Get input embeddings."""
        return self.embed_tokens


class DFlashForCausalLM(nn.Module, CudaGraphMixin):
    """DFlash causal LM for speculative decoding."""

    packed_modules_mapping = {
        'qkv_proj': ['q_proj'],
        'gate_up_proj': ['gate_proj', 'up_proj'],
    }

    def __init__(self,
                 config: PretrainedConfig,
                 ctx_mgr: StepContextManager,
                 dtype: torch.dtype = None,
                 device: torch.device = None,
                 prefix: str = ''):
        super().__init__()
        self.config = config
        self.ctx_mgr = ctx_mgr
        self.dtype = dtype

        # Build model
        self.model = DFlashModel(
            config,
            dtype=dtype,
            device=device,
            prefix=add_prefix('model', prefix),
        )

        # LM head
        self.lm_head = build_rowwise_linear(
            config.hidden_size,
            config.vocab_size,
            bias=False,
            dtype=dtype,
            device=device,
        )

    def forward(
        self,
        input_ids: torch.Tensor,
        position_ids: torch.Tensor,
        past_key_values: List[List[torch.Tensor]],
        attn_metadata: Any = None,
        inputs_embeds: torch.Tensor = None,
        target_hidden_states: torch.Tensor = None,
        **kwargs,
    ) -> torch.Tensor:
        """Model forward, return hidden states for logit computation.

        Args:
            input_ids: Draft token IDs
            position_ids: Position IDs
            past_key_values: KV cache (not used for DFlash)
            attn_metadata: Attention metadata
            inputs_embeds: Pre-computed embeddings
            target_hidden_states: Target model intermediate hidden states

        Returns:
            Hidden states
        """
        hidden_states = self.model(
            input_ids=input_ids,
            target_hidden=target_hidden_states,
            position_ids=position_ids,
            inputs_embeds=inputs_embeds,
        )
        return hidden_states

    def get_logits(self, hidden_states: torch.Tensor) -> torch.Tensor:
        """Compute logits from hidden states."""
        return self.lm_head(hidden_states)

    def update_weights(self):
        """Update weights for weight sharing."""
        if self.config.tie_word_embeddings:
            self.lm_head.weight = self.model.embed_tokens.weight

    def update_model_metas(self, past_key_values=None, context=None, **kwargs):
        """Update model metas during generation.

        DFlash doesn't use KV cache, so this is a no-op.
        """
        pass

    def get_capture_batch_sizes(self):
        """Return empty list since DFlash doesn't use CUDA graphs."""
        return []

    def get_input_embeddings(self):
        """Get input embeddings."""
        return self.model.get_input_embeddings()

    def prepare_inputs_for_generation(
        self,
        past_key_values: List[List[torch.Tensor]],
        inputs_embeds: Optional[torch.Tensor] = None,
        context: StepContext = None,
    ) -> Dict[str, Any]:
        """Prepare inputs for generation."""
        input_ids = context.input_ids
        position_ids = context.position_ids
        attn_metadata = context.attn_metadata
        target_hidden_states = getattr(context, 'target_hidden_states', None)

        # Debug: log if target_hidden_states is None
        if target_hidden_states is None:
            from lmdeploy.utils import get_logger
            logger = get_logger('lmdeploy')
            logger.warning(f'DFlash: target_hidden_states is None in prepare_inputs_for_generation! '
                          f'context has target_hidden_states: {hasattr(context, "target_hidden_states")}')

        return dict(
            input_ids=input_ids,
            position_ids=position_ids,
            past_key_values=past_key_values,
            attn_metadata=attn_metadata,
            inputs_embeds=inputs_embeds,
            target_hidden_states=target_hidden_states,
        )

    def make_buffers_cudagraph(self, graph_meta, **kwargs):
        """Make CUDA graph buffers."""
        max_tokens = graph_meta.max_tokens

        input_buffers = super().make_buffers_cudagraph(graph_meta=graph_meta, **kwargs)
        # DFlash needs target_hidden_states with shape [batch, tokens, num_layers*hidden_size]
        # where num_layers = len(target_layer_ids) = 5 for Qwen3-4B-DFlash
        dflash_cfg = getattr(self.config, 'dflash_config', None)
        if dflash_cfg is not None:
            if isinstance(dflash_cfg, dict):
                target_layer_ids = dflash_cfg.get('target_layer_ids', [1, 10, 19, 28, 37])
            else:
                target_layer_ids = getattr(dflash_cfg, 'target_layer_ids', [1, 10, 19, 28, 37])
        else:
            target_layer_ids = [1, 10, 19, 28, 37]
        num_target_layers = len(target_layer_ids)
        dflash_hidden_size = num_target_layers * self.config.hidden_size

        input_buffers['target_hidden_states'] = input_buffers['input_ids'].new_zeros(
            1, max_tokens, dflash_hidden_size, dtype=self.dtype)

        return input_buffers

    def fill_buffers_cudagraph(self, graph_meta, **kwargs):
        """Fill CUDA graph buffers."""
        new_inputs = super().fill_buffers_cudagraph(graph_meta=graph_meta, **kwargs)

        num_tokens = kwargs['input_ids'].size(-1)
        is_decoding = graph_meta.is_decoding
        input_buffers = graph_meta.input_buffers
        padded_num_tokens = new_inputs['input_ids'].size(-1)

        target_hidden_states = kwargs.get('target_hidden_states')
        if target_hidden_states is not None:
            input_buffers['target_hidden_states'][:, :num_tokens] = target_hidden_states
            if is_decoding:
                new_inputs['target_hidden_states'] = input_buffers['target_hidden_states'][:, :padded_num_tokens, :]
            else:
                new_inputs['target_hidden_states'] = input_buffers['target_hidden_states']

        return new_inputs

    def load_weights(self, weights: Iterable[Tuple[str, torch.Tensor]]):
        """Load DFlash weights.

        Checkpoint naming (standard HF):
            layers.0.self_attn.q_proj.weight -> model.layers.0.self_attn.q_proj.weight
            layers.0.self_attn.k_proj.weight -> model.layers.0.self_attn.k_proj.weight
            layers.0.self_attn.v_proj.weight -> model.layers.0.self_attn.v_proj.weight
            layers.0.mlp.gate_proj.weight -> model.layers.0.gate_up_proj.weight (shard_id=0)
            layers.0.mlp.up_proj.weight -> model.layers.0.gate_up_proj.weight (shard_id=1)
            layers.0.mlp.down_proj.weight -> model.layers.0.down_proj.weight
            fc.weight -> model.fc.weight
            hidden_norm.weight -> model.hidden_norm.weight
            norm.weight -> model.norm.weight
        """
        params_dict = dict(self.named_parameters())

        for name, loaded_weight in weights:
            # Remove 'model.' prefix if present
            if name.startswith('model.'):
                name = name[6:]

            # Skip rotary embedding
            if 'rotary_emb' in name:
                continue

            # Map checkpoint names to model names
            # layers.0.xxx -> model.layers.0.xxx
            target_name = 'model.' + name
            if target_name in params_dict:
                load_weight(params_dict[target_name], loaded_weight)
                continue

            # Handle .mlp. gate_proj and up_proj -> gate_up_proj
            if '.mlp.gate_proj.' in name:
                # layers.0.mlp.gate_proj.weight -> model.layers.0.gate_up_proj.weight
                base_name = name.replace('.mlp.gate_proj.', '.gate_up_proj.')
                base_name = 'model.' + base_name
                if base_name in params_dict:
                    load_weight(params_dict[base_name], loaded_weight, shard_id=0)
                    continue

            if '.mlp.up_proj.' in name:
                base_name = name.replace('.mlp.up_proj.', '.gate_up_proj.')
                base_name = 'model.' + base_name
                if base_name in params_dict:
                    load_weight(params_dict[base_name], loaded_weight, shard_id=1)
                    continue

            # Handle .mlp.down_proj
            if '.mlp.down_proj.' in name:
                target_name = name.replace('.mlp.down_proj.', '.down_proj.')
                target_name = 'model.' + target_name
                if target_name in params_dict:
                    load_weight(params_dict[target_name], loaded_weight)
                    continue

            # Handle fc.weight and hidden_norm.weight
            if name in ['fc.weight', 'hidden_norm.weight']:
                target_name = 'model.' + name
                if target_name in params_dict:
                    load_weight(params_dict[target_name], loaded_weight)
                    continue

            print(f'Warning: Could not find param for weight {name}')
